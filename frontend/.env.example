# Variáveis Obrigatórias
SUPABASE_SECRET_KEY=your-secret-key-here
SUPABASE_URL=https://your-project.supabase.co

# Desenvolvimento Local (não usar na Vercel)
SUPABASE_KEY=your-supabase-publishable-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# Vercel usa estes nomes (não usar no desenvolvimento local)
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Credenciais do usuário de teste (seed.py + testes)
# TEST_EMAIL=teste@labgas.com
# TEST_PASSWORD=123456

# Configurações Opcionais
# INACTIVITY_TIMEOUT_MINUTES=10  # Timeout de sessão (padrão: 10 min)
# ITEMS_PER_PAGE=10              # Itens por página (padrão: 10)
# ALLOWED_ORIGINS=*              # Origens permitidas para CORS (padrão: *)
# LITROS_EQUIVALENTES_KG=956.0  # Litros por kg de gás (padrão: 956.0)
# GAS_KG_DEFAULT=1.0            # Kg padrão de gás (padrão: 1.0)
# CUSTO_DEFAULT=290.00         # Custo padrão (padrão: 290.00)
# RATE_LIMIT=500 per day;200 per hour  # Limite de requisições (padrão: 500/dia, 200/hora)
#   ⚠ AVISO: Se for reduzir, lembre-se que cada operação CRUD faz 3-5 chamadas ao Supabase.
#     Aumentar este limite sem otimizar as consultas pode sobrecarregar o plano Free do Supabase.
#     Valor recomendado: mínimo 200/hora para uso moderado.
# REDIS_URL=                    # URL do Redis para rate limiting persistente (opcional, sem Redis usa memória local)